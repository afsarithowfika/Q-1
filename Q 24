#include <stdio.h>

int main() {
    int n, i, key;
    int arr[100];

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("Enter the element to find: ");
    scanf("%d", &key);

    for(i = n - 1; i >= 0; i--) {
        if(arr[i] == key) {
            printf("Last occurrence is at position %d\n", i + 1);
            return 0;
        }
    }

    printf("Element not found.\n");

    return 0;
}
