#include <stdio.h>

int main() {
    int n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[100];

    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    for(i = 0; i < n - 1; i++) {
        if(arr[i] > arr[i + 1]) {
            printf("Array is NOT sorted.");
            return 0;
        }
    }

    printf("Array is sorted.");

    return 0;
}
