#include <stdio.h>

int main() {
    int arr[] = {12, 45, 7, 89, 23};
    int n = sizeof(arr) / sizeof(arr[0]);

    int min = arr[0];

    for (int i = 1; i < n; i++) {
        if (arr[i] < min) {
            min = arr[i];
        }
    }

    printf("Smallest element = %d\n", min);

    return 0;
}
