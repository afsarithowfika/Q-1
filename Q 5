#include <stdio.h>

int main() {
    int n, i;
    int arr[100];
    int sum = 0;

    // Input the number of elements
    printf("Enter the number of elements: ");
    scanf("%d", &n);

    // Input array elements
    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Calculate sum
    for(i = 0; i < n; i++) {
        sum += arr[i];
    }

    // Display the result
    printf("Sum of array elements = %d\n", sum);

    return 0;
}
