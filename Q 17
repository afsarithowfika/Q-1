#include <stdio.h>

int main() {
    int n, i;
    int arr[100];

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int min = arr[0];
    int maxDiff = arr[1] - arr[0];

    for(i = 1; i < n; i++) {
        if(arr[i] - min > maxDiff)
            maxDiff = arr[i] - min;

        if(arr[i] < min)
            min = arr[i];
    }

    printf("Maximum Difference = %d\n", maxDiff);

    return 0;
}
