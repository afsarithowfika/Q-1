#include <stdio.h>
#include <string.h>

int main() {
    char str[100];
    int i, j, start = 0, max = 1;

    printf("Enter a string: ");
    scanf("%s", str);

    int n = strlen(str);

    for(i = 0; i < n; i++) {

        j = 0;
        while(i-j >= 0 && i+j < n && str[i-j] == str[i+j]) {
            if(2*j+1 > max) {
                max = 2*j+1;
                start = i-j;
            }
            j++;
        }

        j = 0;
        while(i-j >= 0 && i+j+1 < n && str[i-j] == str[i+j+1]) {
            if(2*j+2 > max) {
                max = 2*j+2;
                start = i-j;
            }
            j++;
        }
    }

    printf("Longest Palindromic Substring: ");
    for(i = start; i < start + max; i++)
        printf("%c", str[i]);

    return 0;
}
